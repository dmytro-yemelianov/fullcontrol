# Cloudflare Pages headers for the FullControl demo.
# https://developers.cloudflare.com/pages/configuration/headers/

# WebAssembly must be served with the application/wasm MIME type so the browser can use
# WebAssembly.instantiateStreaming (the fast path). The committed .wasm is immutable per deploy.
/pkg/*.wasm
  Content-Type: application/wasm
  Cache-Control: public, max-age=31536000, immutable

# The generated wasm JS glue and design module are stable per deploy.
/pkg/*.js
  Cache-Control: public, max-age=86400
/designs.js
  Cache-Control: public, max-age=86400

# The Pyodide playground ships a committed wheel; cache it hard.
/playground/*.whl
  Content-Type: application/octet-stream
  Cache-Control: public, max-age=31536000, immutable

# HTML entry points: always revalidate so deploys are picked up immediately.
/
  Cache-Control: public, max-age=0, must-revalidate
/*.html
  Cache-Control: public, max-age=0, must-revalidate

# Baseline security headers for the whole site.
/*
  X-Content-Type-Options: nosniff
  Referrer-Policy: strict-origin-when-cross-origin
  X-Frame-Options: SAMEORIGIN
